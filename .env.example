# JWT secret for token signing (change in production!)
JWT_SECRET=your-secret-key-change-me

# Server port
PORT=3001

# Frontend: set this to the server URL when deploying
# (leave empty for local dev — Vite proxy handles it)
VITE_API_URL=

# Groq API Key for Whisper Speech-To-Text (OpenAI Compatible)
GROQ_API_KEY=gsk_your_groq_api_key_here

# DeepSeek API Key for AI Tutor feedback / analysis
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Pause duration threshold (in milliseconds) for fluency check
PAUSE_THRESHOLD_MS=2000


